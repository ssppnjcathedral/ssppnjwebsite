<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Divine Liturgy Service Book &middot; Saints Peter &amp; Paul Orthodox Cathedral</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=EB+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Cinzel:wght@400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --vellum:#F6F1E8;--vellum-mid:#EDE7DC;--vellum-alt:#E8E0D0;
  --text:#1E1510;--ink:#2C1F16;
  --maroon:#7B1D2A;--maroon-deep:#5C1520;
  --gold:#B88328;--gold-lt:#E8C97A;
  --verdigris:#3D6B5E;--stone:#7A6648;--stone-lt:#A89070;
  --apse:#3B0F18;
  --f-display:'Cormorant Garamond',Georgia,serif;
  --f-body:'EB Garamond',Georgia,serif;
  --f-ui:'Cinzel',Georgia,serif;
  --rule:1px solid var(--maroon);
  --rule-faint:1px solid rgba(123,29,42,.14);
  --rule-hair:1px solid rgba(123,29,42,.07)
}
/* DARK MODE */
body.dark-mode{--vellum:#160810;--vellum-mid:#1E0C15;--vellum-alt:#261018;--text:#EDE7DC;--ink:#C8BDB0}
body.dark-mode{background:var(--vellum);color:var(--text)}
body.dark-mode .nav{background:rgba(22,8,16,.97);border-bottom-color:rgba(123,29,42,.22)}
body.dark-mode .liturgy-layout,body.dark-mode .lit-main{background:var(--vellum)}
body.dark-mode .lit-sidebar{background:var(--vellum);border-left-color:rgba(123,29,42,.20)}
body.dark-mode .sb-panel{background:var(--vellum)}
body.dark-mode .callout-box{background:var(--vellum-mid)}
body.dark-mode .mob-ctx-card{background:var(--vellum-mid)}
body.dark-mode .visit-cta-card{background:var(--vellum-mid)}
body.dark-mode .quote-break{background:var(--vellum)}
body.dark-mode .chapter-bar{background:#2A0A14}
body.dark-mode .section-watermark{opacity:.025}
body.dark-mode .lex-text.people,body.dark-mode .lex-text.all{color:var(--text)}
body.dark-mode .lex-text{color:var(--ink)}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--vellum);color:var(--text);font-family:var(--f-body);font-size:23px;line-height:1.75;overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{color:inherit;text-decoration:none}
.rubric{display:block;font-family:var(--f-ui);font-size:.72rem;font-weight:500;letter-spacing:.20em;text-transform:uppercase;color:var(--stone);margin-bottom:.5rem}
.rubric.light{color:rgba(246,241,232,.55)}
.rubric-rule{display:block;height:1px;background:var(--maroon);margin-bottom:1rem;width:48px}
.btn{display:inline-block;font-family:var(--f-ui);font-size:.72rem;font-weight:500;letter-spacing:.16em;text-transform:uppercase;padding:.85rem 2.2rem;border:1px solid currentColor;cursor:pointer;transition:all .22s;white-space:nowrap}
.btn-maroon{color:var(--vellum);background:var(--maroon);border-color:var(--maroon)}
.btn-maroon:hover{background:var(--maroon-deep)}
.btn-outline{color:var(--maroon);border-color:var(--maroon)}
.btn-outline:hover{background:var(--maroon);color:var(--vellum)}
/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(246,241,232,.97);backdrop-filter:blur(10px);border-bottom:var(--rule-faint)}
.nav-inner{max-width:1380px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:60px;padding:0 2rem}
.nav-logo-name{font-family:var(--f-display);font-weight:500;font-size:1.25rem;color:var(--text);display:block}
.nav-logo-sub{font-family:var(--f-ui);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--stone);display:block}
.nav-links{display:flex;align-items:center;list-style:none}
.nav-links>li{position:relative}
.nav-links>li>a{font-family:var(--f-ui);font-size:.72rem;letter-spacing:.08em;text-transform:uppercase;color:var(--ink);padding:1.1rem .65rem;display:block;transition:color .18s}
.nav-links>li:hover>a{color:var(--maroon)}
.nav-drop{position:absolute;top:100%;left:0;background:var(--vellum);border-top:2px solid var(--maroon);border-bottom:var(--rule-faint);border-left:var(--rule-faint);border-right:var(--rule-faint);min-width:200px;padding:.5rem 0;opacity:0;pointer-events:none;transform:translateY(-4px);transition:all .16s;box-shadow:0 8px 28px rgba(28,20,16,.10)}
.nav-links>li:hover .nav-drop{opacity:1;pointer-events:all;transform:none}
.nav-drop a{display:block;font-family:var(--f-ui);font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--ink);padding:.5rem 1.4rem;transition:color .14s}
.nav-drop a:hover{color:var(--maroon)}
.nav-links .nav-active-parent>a{color:var(--maroon);border-bottom:2px solid var(--gold)}
.nav-drop .nav-active{color:var(--maroon);font-weight:600}
.nav-give{font-family:var(--f-ui);font-size:.76rem;letter-spacing:.14em;text-transform:uppercase;color:var(--vellum);background:var(--maroon);padding:.5rem 1.1rem;transition:background .2s}
.nav-give:hover{background:var(--maroon-deep)}
.nav-hamburger{display:none;flex-direction:column;justify-content:space-between;width:28px;height:20px;cursor:pointer;padding:0;background:none;border:none;z-index:400}
.nav-hamburger span{display:block;width:100%;height:2px;background:var(--maroon);transition:all .28s ease;transform-origin:center}
.nav-hamburger.open span:nth-child(1){transform:translateY(9px) rotate(45deg)}
.nav-hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
.nav-hamburger.open span:nth-child(3){transform:translateY(-9px) rotate(-45deg)}
/* MOBILE DRAWER */
.nav-drawer{position:fixed;top:0;right:0;width:300px;max-width:85vw;height:100vh;background:var(--apse);z-index:350;transform:translateX(100%);transition:transform .32s cubic-bezier(.4,0,.2,1);display:flex;flex-direction:column;overflow-y:auto}
.nav-drawer.open{transform:translateX(0)}
.nav-drawer-overlay{position:fixed;inset:0;background:rgba(21,8,4,.65);z-index:340;opacity:0;pointer-events:none;transition:opacity .32s}
.nav-drawer-overlay.open{opacity:1;pointer-events:all}
.nav-drawer-head{padding:1.5rem 1.75rem 1rem;border-bottom:1px solid rgba(255,255,255,.08);display:flex;align-items:center;justify-content:space-between}
.nav-drawer-logo{font-family:var(--f-display);font-weight:500;font-size:1.1rem;color:#fff}
.nav-drawer-logo span{font-family:var(--f-ui);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.45);display:block;margin-top:2px}
.nav-drawer-close{width:32px;height:32px;background:rgba(255,255,255,.08);border:none;color:rgba(255,255,255,.65);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:background .2s}
.nav-drawer-close:hover{background:rgba(255,255,255,.15)}
.nav-drawer-links{padding:1rem 0;flex:1}
.nav-drawer-links a{display:block;font-family:var(--f-ui);font-size:.74rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(246,241,232,.70);padding:.9rem 1.75rem;border-bottom:1px solid rgba(255,255,255,.05);transition:all .18s}
.nav-drawer-links a:hover{color:#fff;background:rgba(255,255,255,.05)}
.nav-drawer-links .drawer-section{font-family:var(--f-ui);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(184,131,40,.55);padding:.85rem 1.75rem .35rem;display:block}
.nav-drawer-give{margin:1.25rem 1.75rem;display:block;text-align:center;font-family:var(--f-ui);font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;padding:.85rem;background:var(--maroon);color:var(--vellum);transition:background .2s}
.nav-drawer-give:hover{background:var(--maroon-deep)}
/* HERO */
.page-hero{padding-top:60px;background:linear-gradient(to right,rgba(59,15,24,.93) 0%,rgba(59,15,24,.75) 55%,rgba(59,15,24,.42) 100%),url('/images/heroes/divine-liturgy.webp') center/cover no-repeat;background-color:var(--apse);min-height:400px;display:flex;align-items:center;position:relative}
.page-hero-inner{max-width:1380px;margin:0 auto;padding:5rem 6rem 4rem 3.5rem;width:100%}
.page-title{font-family:var(--f-display);font-weight:300;font-size:clamp(2.5rem,5vw,4.5rem);line-height:.95;color:#fff;margin:.5rem 0 .75rem;max-width:700px}
.page-title em{font-style:italic;font-weight:300}
.page-subtitle{font-family:var(--f-display);font-style:italic;font-size:1.55rem;color:rgba(255,255,255,.62);margin-top:.5rem;max-width:520px;line-height:1.45}
.breadcrumb{font-family:var(--f-ui);font-size:.72rem;font-weight:500;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.42);margin-bottom:1.5rem}
.breadcrumb a{color:rgba(232,201,122,.70)}
.breadcrumb a:hover{color:var(--gold-lt)}
/* CHAPTER BAR */
.chapter-bar{background:var(--maroon);padding:.65rem 4rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap}
.cbar-text{font-family:var(--f-ui);font-size:.72rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:rgba(246,241,232,.60)}
.cbar-text.bright{color:rgba(246,241,232,.90)}
.cbar-links{display:flex;gap:1.25rem;flex-wrap:wrap}
.cbar-link{font-family:var(--f-ui);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(246,241,232,.55);transition:color .18s;cursor:pointer;border:none;background:none;padding:0}
.cbar-link:hover,.cbar-link.cbar-active{color:rgba(232,201,122,.92)}
/* THREE-COLUMN LAYOUT */
.liturgy-layout{display:grid;grid-template-columns:72px 1fr 300px;max-width:1380px;margin:0 auto;background:var(--vellum);position:relative;min-height:80vh}
/* LEFT NAV RAIL */
.lit-rail{position:sticky;top:60px;height:calc(100vh - 60px);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:1.2rem 0;border-right:var(--rule-faint);z-index:10;opacity:0;transition:opacity .5s}
.lit-rail.rail-visible{opacity:1}
.rail-connector{width:1px;background:rgba(123,29,42,.10);flex:1;max-height:10px}
.rail-item{display:flex;flex-direction:column;align-items:center;cursor:pointer;position:relative;padding:.12rem 0}
.rail-dot-wrap{width:36px;height:26px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px}
.rail-dot{width:6px;height:6px;border-radius:50%;border:1.5px solid rgba(123,29,42,.28);background:transparent;transition:all .28s cubic-bezier(.22,1,.36,1)}
.rail-item.rail-active .rail-dot{background:var(--maroon);border-color:var(--maroon);width:8px;height:8px;box-shadow:0 0 0 3px rgba(123,29,42,.12)}
.rail-num{font-family:var(--f-ui);font-size:.48rem;letter-spacing:.05em;color:rgba(123,29,42,.28);display:block;transition:color .28s;line-height:1}
.rail-item.rail-active .rail-num{color:var(--maroon)}
.rail-label{position:absolute;left:calc(100% + 10px);top:50%;transform:translateY(-50%);background:var(--vellum);border:var(--rule-faint);border-left:2px solid var(--maroon);padding:.28rem .7rem;font-family:var(--f-ui);font-size:.58rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--maroon);white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .18s;box-shadow:0 2px 10px rgba(28,20,16,.08)}
.rail-item:hover .rail-label{opacity:1}
/* MAIN ARTICLE */
.lit-main{padding:4.5rem 4rem 7rem 3.5rem;max-width:700px}
/* SECTION BLOCKS */
.lit-section{padding:4.5rem 0 2.5rem;border-top:var(--rule-faint);position:relative;scroll-margin-top:80px}
.lit-section:first-child{border-top:none;padding-top:0}
.section-watermark{font-family:var(--f-display);font-weight:300;font-size:9rem;color:var(--maroon);opacity:.04;position:absolute;right:-1.5rem;top:.25rem;line-height:1;pointer-events:none;user-select:none;z-index:0}
.section-tag{font-family:var(--f-ui);font-size:.62rem;font-weight:500;letter-spacing:.20em;text-transform:uppercase;color:var(--stone);display:block;margin-bottom:.6rem;position:relative;z-index:1}
.section-head-row{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:.4rem;position:relative;z-index:1}
.section-head{font-family:var(--f-display);font-weight:400;font-size:clamp(1.7rem,2.8vw,2.4rem);color:var(--text);line-height:1.08;flex:1}
.section-head em{font-style:italic;font-weight:300}
.section-sub{font-family:var(--f-display);font-style:italic;font-size:1.5rem;color:var(--maroon);display:block;margin-bottom:1.85rem;line-height:1.38;position:relative;z-index:1}
.prose{font-family:var(--f-body);font-size:1.15rem;line-height:1.88;color:var(--ink);hyphens:auto;position:relative;z-index:1}
.prose p{margin-bottom:1.3em}
.prose strong{font-weight:500;color:var(--text)}
/* LITURGICAL EXCHANGE */
.lex-block{position:relative;z-index:1;margin:1.6rem 0}
.lex-direction{display:block;font-family:var(--f-body);font-style:italic;font-size:1rem;color:var(--stone);margin:1.2rem 0 .6rem;line-height:1.65}
.lex-exchange{display:flex;gap:.85rem;align-items:baseline;margin:.5rem 0}
.lex-label{font-family:var(--f-ui);font-size:.54rem;letter-spacing:.12em;text-transform:uppercase;flex-shrink:0;width:52px;padding-top:.2rem;line-height:1.2}
.lex-label.priest{color:var(--stone)}
.lex-label.people{color:var(--maroon)}
.lex-label.choir{color:var(--verdigris)}
.lex-label.reader{color:var(--stone-lt)}
.lex-label.all{color:var(--maroon)}
.lex-text{font-family:var(--f-body);font-size:1.1rem;line-height:1.82;color:var(--ink);flex:1}
.lex-text.people,.lex-text.all{color:var(--text);font-size:1.15rem}
.lex-note{font-family:var(--f-ui);font-size:.54rem;letter-spacing:.10em;text-transform:uppercase;color:var(--stone);margin-left:.4rem;vertical-align:baseline}
.lex-verse{font-family:var(--f-display);font-style:italic;font-size:1.1rem;line-height:2;padding-left:1.75rem;border-left:2px solid rgba(123,29,42,.18);margin:.8rem 0 .8rem 52px;color:var(--text)}
.lex-instruct{display:block;font-family:var(--f-ui);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--stone);margin:.6rem 0 0 52px}
/* MUSIC BUTTON */
.music-btn{flex-shrink:0;width:30px;height:30px;border:none;background:none;cursor:not-allowed;color:var(--gold);opacity:.28;padding:0;display:flex;align-items:center;justify-content:center;margin-top:.5rem;transition:opacity .2s;border-radius:4px}
.music-btn.available{opacity:.80;cursor:pointer}
.music-btn.available:hover{opacity:1;background:rgba(184,131,40,.10)}
/* CALLOUT BOX */
.callout-box{background:var(--vellum-mid);border-left:3px solid var(--gold);padding:1.5rem 1.65rem;margin:2.5rem 0;position:relative;z-index:1}
.callout-tag{font-family:var(--f-ui);font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);display:block;margin-bottom:.4rem}
.callout-head{font-family:var(--f-display);font-weight:500;font-size:1.5rem;color:var(--text);margin-bottom:.2rem;line-height:1.15}
.callout-sub{font-family:var(--f-body);font-size:1.05rem;color:var(--stone);display:block;margin-bottom:.9rem}
.callout-body{font-family:var(--f-body);font-size:1.05rem;line-height:1.80;color:var(--ink)}
.callout-body strong{color:var(--text);font-weight:500}
/* SUBSECTION */
.lit-subsection{margin:3rem 0 0;padding-top:2rem;border-top:var(--rule-faint)}
.subsection-head{font-family:var(--f-display);font-weight:400;font-size:clamp(1.3rem,2vw,1.75rem);color:var(--text);line-height:1.1;margin-bottom:.25rem}
.subsection-sub{font-family:var(--f-display);font-style:italic;font-size:1.15rem;color:var(--maroon);display:block;margin-bottom:.9rem}
.subsection-num{font-family:var(--f-ui);font-size:.62rem;letter-spacing:.20em;text-transform:uppercase;color:var(--stone);display:block;margin-bottom:.5rem}
/* MOBILE SIDEBAR CARDS */
.mob-ctx-card{display:none;background:var(--vellum-mid);border-left:3px solid var(--gold);padding:1.35rem 1.5rem;margin:1.75rem 0}
.mob-ctx-tag{font-family:var(--f-ui);font-size:.58rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);display:block;margin-bottom:.45rem}
.mob-ctx-body{font-family:var(--f-body);font-size:.92rem;line-height:1.78;color:var(--ink)}
/* RIGHT SIDEBAR */
.lit-sidebar{position:sticky;top:60px;height:calc(100vh - 60px);border-left:var(--rule-faint);background:var(--vellum);overflow:hidden}
.sidebar-track{height:100%;position:relative;overflow:hidden}
.sb-panel{position:absolute;inset:0;padding:2.25rem 2rem 2.25rem 2.25rem;opacity:0;transform:translateY(10px);transition:opacity .38s cubic-bezier(.22,1,.36,1),transform .38s cubic-bezier(.22,1,.36,1);pointer-events:none;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(123,29,42,.15) transparent}
.sb-panel.sb-active{opacity:1;transform:none;pointer-events:all}
.sb-panel-tag{font-family:var(--f-ui);font-size:.60rem;letter-spacing:.18em;text-transform:uppercase;color:var(--stone);display:block;margin-bottom:.5rem}
.sb-rule{height:1px;background:rgba(123,29,42,.10);margin:1.1rem 0}
.sb-panel-head{font-family:var(--f-display);font-weight:400;font-size:1.15rem;color:var(--text);line-height:1.25;margin-bottom:.5rem;display:block}
.sb-body{font-family:var(--f-body);font-size:1.05rem;line-height:1.78;color:var(--ink);opacity:.90}
.sb-body em{font-style:italic}.sb-body strong{font-weight:500}
.sb-icon{width:100%;max-height:170px;object-fit:cover;object-position:center top;margin-bottom:.8rem;display:block;filter:sepia(.08)}
.sb-icon-cap{font-family:var(--f-ui);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--stone);display:block;padding-bottom:.65rem;margin-bottom:1rem;border-bottom:var(--rule-hair)}
.sb-blockquote{border-left:2px solid var(--maroon);padding-left:1rem;margin:1rem 0}
.sb-blockquote-text{font-family:var(--f-display);font-style:italic;font-size:1.2rem;line-height:1.55;color:var(--text);display:block}
.sb-blockquote-attr{font-family:var(--f-ui);font-size:.58rem;letter-spacing:.13em;text-transform:uppercase;color:var(--stone);display:block;margin-top:.45rem}
.sb-scripture{text-align:center;padding:.85rem .5rem}
.sb-scripture-text{font-family:var(--f-display);font-style:italic;font-size:1rem;color:var(--maroon);line-height:1.5;display:block;margin-bottom:.3rem}
.sb-scripture-ref{font-family:var(--f-ui);font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:var(--stone)}
.sb-chi-rho{text-align:center;font-size:2.5rem;color:var(--maroon);opacity:.22;display:block;margin:1.5rem 0 .5rem;line-height:1}
/* QUOTE BREAK */
.quote-break{margin:0;padding:4rem 4.5rem;background:var(--vellum);border-top:var(--rule-faint);border-bottom:var(--rule-faint)}
.qb-inner{max-width:680px;margin:0 auto;padding-left:2rem;border-left:3px solid var(--maroon)}
.qb-text{font-family:var(--f-display);font-style:italic;font-weight:300;font-size:clamp(1.5rem,3vw,2.2rem);line-height:1.4;color:var(--text);margin-bottom:.75rem}
.qb-attr{font-family:var(--f-ui);font-size:.72rem;letter-spacing:.20em;text-transform:uppercase;color:var(--maroon);display:block}
/* CTA + FOOTER */
.visit-cta-card{background:var(--vellum-mid);border:var(--rule-faint);border-left:3px solid var(--gold);padding:1.85rem 2.1rem;margin:3rem 0}
.visit-cta-card h3{font-family:var(--f-display);font-weight:400;font-size:1.5rem;color:var(--text);margin:.3rem 0 .5rem}
.visit-cta-card p{font-family:var(--f-body);font-size:.94rem;line-height:1.78;color:var(--ink);margin-bottom:1.25rem}
.visit-cta-btns{display:flex;gap:.75rem;flex-wrap:wrap}
.lit-cta{background:var(--maroon);padding:3.75rem 4.5rem;text-align:center}
.lit-cta-head{font-family:var(--f-display);font-weight:300;font-size:clamp(2rem,3.5vw,3rem);color:#fff;margin-bottom:.4rem;line-height:1.1}
.lit-cta-head em{font-style:italic}
.lit-cta-sub{font-family:var(--f-display);font-style:italic;font-size:1.1rem;color:rgba(255,255,255,.60);margin-bottom:2rem;display:block}
.lit-cta-btns{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
footer{background:var(--apse);border-top:1px solid rgba(184,131,40,.14);padding:3rem 4.5rem 2rem}
.footer-cross{display:block;text-align:center;font-size:1.1rem;color:rgba(184,131,40,.45);letter-spacing:.8em;padding-left:.8em;margin-bottom:2.5rem}
.footer-cols{max-width:1380px;margin:0 auto;display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:4rem;margin-bottom:2.5rem}
